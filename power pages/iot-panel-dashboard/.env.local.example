# Power Pages SPA — local development environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
#
# SECURITY NOTE: All VITE_* values are baked into the JS bundle at build time
# and are visible to any browser user. Never put secrets (keys, passwords,
# tokens) here. Secrets belong in Azure Function app settings — see
# azure infrastructure/azure-functions/iot-signalr-func/local.settings.json.template

# Azure Function base URL (no trailing slash or path)
# Found in Azure Portal → Function App → Overview → URL
VITE_SIGNALR_NEGOTIATE_URL=https://your-function-app.azurewebsites.net

# URL of the server-side Direct Line token endpoint
# This is your Azure Function's /api/directline-token route — NOT a secret.
# The function exchanges the real Direct Line secret for a short-lived token server-side.
# e.g. https://your-function-app.azurewebsites.net/api/directline-token
VITE_DIRECTLINE_TOKEN_URL=https://your-function-app.azurewebsites.net/api/directline-token

# (Optional) Override the target device ID (default: raspberry-pi-iotpanel)
# VITE_TARGET_DEVICE_ID=raspberry-pi-iotpanel

# Dataverse org URL — used by vite dev server proxy for /api/data/* calls
# Found in Power Platform admin center → Environments → your env → Environment URL
VITE_DATAVERSE_URL=https://your-org.crm.dynamics.com
