# Dataverse client secrets — one per environment
# Copy this file to .env at the repo root and fill in real values.
# NEVER commit .env to source control.

# Dev environment secret
DATAVERSE_CLIENT_SECRET_DEV=your-dev-secret-here

# Staging environment secret (add when ready)
# DATAVERSE_CLIENT_SECRET_STAGING=your-staging-secret-here

# Production environment secret (add when ready)
# DATAVERSE_CLIENT_SECRET_PROD=your-prod-secret-here
