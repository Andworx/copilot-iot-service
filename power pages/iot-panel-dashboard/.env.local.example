# Power Pages SPA — local development environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Azure Function base URL for the SignalR negotiate endpoint
# Found in Azure Portal → Function App → Overview → URL
VITE_SIGNALR_NEGOTIATE_URL=https://your-function-app.azurewebsites.net

# Azure Function access key for the negotiate endpoint
# Found in Azure Portal → Function App → Functions → negotiate → Function Keys
VITE_SIGNALR_FUNC_KEY=your-function-key-here

# (Optional) Override the target device ID (default: raspberry-pi-iotpanel)
# VITE_TARGET_DEVICE_ID=raspberry-pi-iotpanel

# Dataverse org URL — used by vite dev server proxy for /api/data/* calls
# Found in Power Platform admin center → Environments → your env → Environment URL
VITE_DATAVERSE_URL=https://your-org.crm.dynamics.com

# Copilot Studio Direct Line secret — wires the "Help Fix" button to the agent
# Get from: Copilot Studio → your agent → Channels → Direct Line → copy the Secret key
# NOTE: Use the Direct Line channel secret directly (same pattern as Agentic-Growth-Team).
#       Do NOT use the Mobile app token endpoint or M365 Agents SDK connection string.
VITE_COPILOT_DIRECTLINE_SECRET=your-directline-secret-here
