# Azure IoT Hub Configuration
# Copy this file to .env and fill in your connection string
# Format: HostName=xxx.azure-devices.net;DeviceId=xxx;SharedAccessKey=xxx
#
# SECURITY: Never commit .env to source control — it is gitignored.
# The connection string contains a shared access key (secret).

IOT_HUB_CONNECTION_STRING=

# Device identification — must match the device registered in Azure IoT Hub
DEVICE_ID=raspberry-pi-iotpanel

# GitHub Personal Access Token — required for auto-deploy to pull code updates.
# Create a fine-grained token at https://github.com/settings/tokens with
# read-only access to the Andworx/copilot-iot-service repository (Contents: Read).
# No SSH keys needed — auto-deploy uses HTTPS + this token.
GITHUB_TOKEN=
